# Normalize text files to LF in the repository (Windows + Linux + macOS).
# Without this, Windows-authored commits can land CRLF blobs that then look
# permanently dirty under `text eol=lf` attributes and confuse PR diffs.
* text=auto eol=lf

# Source and config (explicit; same policy as auto)
*.py text eol=lf
*.pyi text eol=lf
*.md text eol=lf
*.js text eol=lf
*.mjs text eol=lf
