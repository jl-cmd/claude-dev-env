# Local, git-ignored configuration for the claude-dev-env package.
# Copy this file to `.env` in the same directory and fill in the values.
# `.env` is git-ignored; `.env.example` is committed as the documented template.

# Copilot premium-request quota pre-check.
#
# Names the GitHub account whose remaining Copilot premium-interaction quota the
# autoconverge and pr-converge Copilot pre-check reads (via `gh api
# copilot_internal/user`) before spawning any Copilot review. When the account
# is out of premium-request quota, the Copilot step is skipped with no agent
# spawned. Only the login is stored here — never a token; the token is resolved
# from `gh auth token -u <login>`, so the account must be `gh auth login`-ed.
#
# The `--account <login>` flag and the `COPILOT_QUOTA_ACCOUNT` environment
# variable both override this file, in that order.
COPILOT_QUOTA_ACCOUNT=your-github-login